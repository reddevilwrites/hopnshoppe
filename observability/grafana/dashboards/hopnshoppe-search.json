{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "search_service_values{metric=\"cache_hit_rate\"}",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "search_service_values{metric=\"l1_size_active\"}",
          "refId": "A"
        }
      ],
      "title": "L1 Active Cache Entries",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "ingestion_worker_db_connected",
          "refId": "A"
        }
      ],
      "title": "Ingestion DB Connected",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(search_request_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "title": "Search p95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(search_service_events_total[5m])) by (metric)",
          "legendFormat": "{{metric}}",
          "refId": "A"
        }
      ],
      "title": "Search Event Rates",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(ingestion_worker_events_total[5m])) by (event_type, outcome)",
          "legendFormat": "{{event_type}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Ingestion Worker Event Rates",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Embedding model calls vs total search requests. The gap between the two lines shows how many requests were served entirely from cache without invoking the embedding model. A wider gap means more cost savings.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(search_requests_total[5m]))",
          "legendFormat": "Total requests/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(search_service_events_total{metric=\"embeddings_computed\"}[5m]))",
          "legendFormat": "Embedding model calls/s",
          "refId": "B"
        }
      ],
      "title": "Embedding Model Calls vs Total Requests",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "HopnShoppe Search and Ingestion",
  "uid": "hopnshoppe-search",
  "version": 2,
  "weekStart": ""
